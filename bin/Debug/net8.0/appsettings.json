{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Error"
    }
  },
  "ConnectionStrings": {
    "SQLConnection": "Server=(localdb)\\MSSQLLocalDB;Database=OrderSystemDb;Trusted_Connection=True;TrustServerCertificate=True;",
    "ServiceBus": "UseDevelopmentStorage=true"
  },
  "CosmosDb": {
    "Endpoint": "https://localhost:8081",
    "Key": "mock-or-local-key",
    "DatabaseName": "OrderSystem",
    "ContainerName": "Payments"
  },
  "Messaging": {
    "OrderCreatedQueue": "order-created",
    "PaymentCompletedQueue": "payment-completed",
    "EmailQueue": "email-notifications"
  },
  "ExternalServices": {
    "PaymentProviderBaseUrl": "https://mock-payment-provider.local",
    "EmailProviderBaseUrl": "https://mock-email-provider.local"
  },
  "AllowedHosts": "*"
}
